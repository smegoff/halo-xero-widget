<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <title><%= clientName %> — Statement</title>
  <style>
    body {
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      font-size: 12px;
      color: #111827;
      margin: 0;
      padding: 24px;
    }
    h1 {
      font-size: 20px;
      margin: 0 0 4px 0;
    }
    .subtitle {
      font-size: 11px;
      color: #6b7280;
      margin-bottom: 16px;
    }
    .summary {
      display: flex;
      gap: 16px;
      margin-bottom: 16px;
    }
    .summary-card {
      flex: 1;
      border-radius: 8px;
      padding: 8px 10px;
      background: #eff6ff;
    }
    .summary-card.red {
      background: #fef2f2;
    }
    .summary-label {
      font-size: 10px;
      color: #6b7280;
      margin-bottom: 4px;
    }
    .summary-value {
      font-size: 14px;
      font-weight: 600;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 8px;
    }
    thead {
      background: #f3f4f6;
    }
    th, td {
      padding: 6px 8px;
      border: 1px solid #e5e7eb;
      font-size: 11px;
    }
    th {
      text-align: left;
    }
    td.num {
      text-align: right;
    }
    tfoot td {
      font-weight: 600;
      background: #f9fafb;
    }
  </style>
</head>
<body>
  <h1><%= clientName %> — Statement</h1>
  <div class="subtitle">
    As at <%= asAt %> — Tenant: <%= tenantName || "Xero" %>
  </div>

  <div class="summary">
    <div class="summary-card">
      <div class="summary-label">Account Balance</div>
      <div class="summary-value">$<%= accountBal %></div>
    </div>
    <div class="summary-card red">
      <div class="summary-label">Overdue Balance</div>
      <div class="summary-value">$<%= overdueBal %></div>
    </div>
  </div>

  <table>
    <thead>
      <tr>
        <th>Date</th>
        <th>Type</th>
        <th>Number</th>
        <th>Due Date</th>
        <th class="num">Total ($)</th>
        <th class="num">Balance ($)</th>
      </tr>
    </thead>
    <tbody>
      <% rows.forEach(r => { %>
      <tr>
        <td><%= r.date %></td>
        <td><%= r.type %></td>
        <td><%= r.number %></td>
        <td><%= r.due %></td>
        <td class="num"><%= r.total %></td>
        <td class="num"><%= r.balance %></td>
      </tr>
      <% }) %>
    </tbody>
    <tfoot>
      <tr>
        <td colspan="4">Totals</td>
        <td class="num">$<%= totalAmount %></td>
        <td class="num">$<%= totalBalance %></td>
      </tr>
    </tfoot>
  </table>
</body>
</html>
