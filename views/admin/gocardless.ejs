<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>GoCardless Settings</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[#f3f6fa] min-h-screen p-6 text-[#0f172a]" style="font-family: Roboto, 'Segoe UI', Arial, sans-serif;">
  <div class="max-w-6xl mx-auto">
    <div class="mb-6 flex items-start justify-between gap-4">
      <div>
        <h1 class="text-[24px] font-semibold tracking-tight">GoCardless Settings</h1>
        <p class="text-sm text-slate-500 mt-1">
          Configure live API access and map Xero Contact GUIDs to GoCardless customer IDs.
        </p>
      </div>
      <a href="/admin" class="inline-flex px-4 py-2 rounded-full bg-white border border-[#dbe3ec] text-sm font-medium hover:bg-[#f6fbfb]">
        Back to Admin
      </a>
    </div>

    <% if (flash?.success) { %>
      <div class="mb-4 rounded-lg border border-[#b6dcda] bg-[#e6f4f3] px-4 py-3 text-sm text-[#087f7b]">
        <%= flash.success %>
      </div>
    <% } %>

    <% if (flash?.error) { %>
      <div class="mb-4 rounded-lg border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-800">
        <%= flash.error %>
      </div>
    <% } %>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 mb-6">
      <div class="bg-white rounded-lg shadow-sm border border-[#dbe3ec] p-5 lg:col-span-2">
        <div class="flex items-start justify-between gap-4 mb-4">
          <div>
            <h2 class="text-xl font-semibold">Live API Token</h2>
            <p class="text-sm text-slate-500 mt-1">
              The token is never displayed after saving.
            </p>
          </div>
          <span class="inline-flex px-3 py-1 rounded-full text-sm font-medium
            <%= runtimeConfig.goCardlessAccessTokenConfigured ? 'bg-[#e6f4f3] text-[#087f7b]' : 'bg-amber-100 text-amber-800' %>">
            <%= runtimeConfig.goCardlessAccessTokenConfigured ? 'Configured' : 'Missing' %>
          </span>
        </div>

        <form method="POST" action="/admin/gocardless/token" class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-3">
          <input
            type="password"
            name="goCardlessAccessToken"
            autocomplete="new-password"
            placeholder="Paste new GoCardless live access token"
            required
            class="w-full rounded-lg border border-[#dbe3ec] px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#087f7b]/20 focus:border-[#087f7b]"
          />
          <button type="submit" class="inline-flex justify-center px-4 py-2 rounded-full bg-[#087f7b] text-white text-sm font-medium hover:bg-[#066b68]">
            Save Token
          </button>
        </form>

        <div class="mt-4 flex flex-wrap items-center gap-3 text-xs text-slate-500">
          <span>Source: <span class="font-medium"><%= runtimeConfig.goCardlessAccessTokenSource %></span></span>
          <span>Environment: <span class="font-medium"><%= runtimeConfig.goCardlessEnvironment %></span></span>
          <% if (runtimeConfig.goCardlessTokenUpdatedAt) { %>
            <span>Override updated: <span class="font-medium"><%= runtimeConfig.goCardlessTokenUpdatedAt %></span></span>
          <% } %>
        </div>
      </div>

      <div class="bg-white rounded-lg shadow-sm border border-[#dbe3ec] p-5">
        <h2 class="text-xl font-semibold mb-4">Actions</h2>
        <div class="space-y-3">
          <a href="/admin/gocardless/test" class="block w-full rounded-lg border border-[#dbe3ec] px-4 py-3 text-sm font-medium hover:bg-[#f6fbfb]">
            Test GoCardless API
          </a>
          <form method="POST" action="/admin/gocardless/auto-map" onsubmit="return confirm('Scan active and in-progress GoCardless mandates and create missing mappings using exposed Xero GUIDs, exact names, or unique Xero email matches? Existing manual mappings are preserved.');">
            <button type="submit" class="block w-full rounded-lg border border-[#b6dcda] bg-[#e6f4f3] px-4 py-3 text-left text-sm font-medium text-[#087f7b] hover:bg-[#d9eeed]">
              Auto-map Eligible Mandates
            </button>
          </form>
          <form method="POST" action="/admin/gocardless/token/clear" onsubmit="return confirm('Clear only the admin override? The .env token will still be used if it exists.');">
            <button type="submit" class="block w-full rounded-lg border border-[#f3c5c7] px-4 py-3 text-left text-sm font-medium text-rose-700 hover:bg-rose-50">
              Clear Admin Token Override
            </button>
          </form>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 mb-6">
      <div class="bg-white rounded-lg shadow-sm border border-[#dbe3ec] p-5 lg:col-span-2">
        <div class="flex items-start justify-between gap-4 mb-4">
          <div>
            <h2 class="text-xl font-semibold">Webhook Endpoint</h2>
            <p class="text-sm text-slate-500 mt-1">
              Add this URL in GoCardless and save the endpoint secret here.
            </p>
          </div>
          <span class="inline-flex px-3 py-1 rounded-full text-sm font-medium
            <%= runtimeConfig.goCardlessWebhookSecretConfigured ? 'bg-[#e6f4f3] text-[#087f7b]' : 'bg-amber-100 text-amber-800' %>">
            <%= runtimeConfig.goCardlessWebhookSecretConfigured ? 'Secret configured' : 'Secret missing' %>
          </span>
        </div>

        <label class="block">
          <span class="text-sm text-slate-500">Webhook URL</span>
          <input
            readonly
            value="<%= runtimeConfig.goCardlessWebhookUrl %>"
            class="mt-1 w-full rounded-lg border border-[#dbe3ec] bg-[#f8fafc] px-3 py-2 text-sm text-slate-700"
          />
        </label>

        <form method="POST" action="/admin/gocardless/webhook-secret" class="mt-4 grid grid-cols-1 md:grid-cols-[1fr_auto] gap-3">
          <input
            type="password"
            name="goCardlessWebhookSecret"
            autocomplete="new-password"
            placeholder="Paste GoCardless webhook endpoint secret"
            required
            class="w-full rounded-lg border border-[#dbe3ec] px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#087f7b]/20 focus:border-[#087f7b]"
          />
          <button type="submit" class="inline-flex justify-center px-4 py-2 rounded-full bg-[#087f7b] text-white text-sm font-medium hover:bg-[#066b68]">
            Save Secret
          </button>
        </form>

        <div class="mt-4 flex flex-wrap items-center gap-3 text-xs text-slate-500">
          <span>Secret source: <span class="font-medium"><%= runtimeConfig.goCardlessWebhookSecretSource %></span></span>
          <% if (runtimeConfig.goCardlessWebhookSecretUpdatedAt) { %>
            <span>Override updated: <span class="font-medium"><%= runtimeConfig.goCardlessWebhookSecretUpdatedAt %></span></span>
          <% } %>
          <span>Last received: <span class="font-medium"><%= webhookOverview.lastReceivedAt || "Never" %></span></span>
        </div>
      </div>

      <div class="bg-white rounded-lg shadow-sm border border-[#dbe3ec] p-5">
        <h2 class="text-xl font-semibold mb-4">Webhook Actions</h2>
        <div class="space-y-3">
          <form method="POST" action="/admin/gocardless/reconcile" onsubmit="return confirm('Reconcile mapped GoCardless customers using the public API fallback? Webhook-derived states will not be overwritten.');">
            <button type="submit" class="block w-full rounded-lg border border-[#b6dcda] bg-[#e6f4f3] px-4 py-3 text-left text-sm font-medium text-[#087f7b] hover:bg-[#d9eeed]">
              Reconcile GoCardless Mandates
            </button>
          </form>
          <form method="POST" action="/admin/gocardless/webhook-secret/clear" onsubmit="return confirm('Clear only the webhook secret admin override? The .env secret will still be used if it exists.');">
            <button type="submit" class="block w-full rounded-lg border border-[#f3c5c7] px-4 py-3 text-left text-sm font-medium text-rose-700 hover:bg-rose-50">
              Clear Webhook Secret Override
            </button>
          </form>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6">
      <div class="bg-white rounded-lg shadow-sm border border-[#dbe3ec] p-5">
        <h2 class="text-xl font-semibold">Recent Mandate Webhooks</h2>
        <div class="mt-4 space-y-2">
          <% if (!webhookOverview.recentEvents.length) { %>
            <div class="text-sm text-slate-500">No mandate webhook events received yet.</div>
          <% } %>
          <% webhookOverview.recentEvents.forEach(event => { %>
            <div class="rounded-lg border border-[#dbe3ec] bg-[#fbfcfd] p-3 text-sm">
              <div class="flex flex-wrap items-center gap-2">
                <span class="font-medium"><%= event.action %></span>
                <span class="text-xs text-slate-500"><%= event.processing_status %></span>
              </div>
              <div class="mt-1 text-xs text-slate-500 break-all">Mandate: <%= event.mandate_id || "n/a" %></div>
              <div class="text-xs text-slate-500 break-all">Customer: <%= event.customer_id || "n/a" %></div>
              <div class="text-xs text-slate-500">Received: <%= event.received_at %></div>
            </div>
          <% }) %>
        </div>
      </div>

      <div class="bg-white rounded-lg shadow-sm border border-[#dbe3ec] p-5">
        <h2 class="text-xl font-semibold">Webhook Processing Failures</h2>
        <div class="mt-4 space-y-2">
          <% if (!webhookOverview.failedEvents.length) { %>
            <div class="text-sm text-slate-500">No failed webhook events.</div>
          <% } %>
          <% webhookOverview.failedEvents.forEach(event => { %>
            <div class="rounded-lg border border-rose-200 bg-rose-50 p-3 text-sm text-rose-900">
              <div class="font-medium"><%= event.resource_type %> / <%= event.action %></div>
              <div class="mt-1 text-xs break-all">Event: <%= event.event_id %></div>
              <div class="text-xs break-all">Mandate: <%= event.mandate_id || "n/a" %></div>
              <div class="text-xs">Error: <%= event.processing_error || "Unknown error" %></div>
            </div>
          <% }) %>
        </div>
      </div>
    </div>

    <div id="unmapped-mandates" class="bg-white rounded-lg shadow-sm border border-[#dbe3ec] p-5 mb-6">
      <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
        <div>
          <h2 class="text-xl font-semibold">Unmapped GoCardless Mandates</h2>
          <p class="text-sm text-slate-500 mt-1">
            Eligible GoCardless customers that are not yet mapped to a Xero Contact GUID.
          </p>
        </div>
        <div class="flex flex-wrap gap-2 text-xs">
          <span class="rounded-full bg-slate-100 px-3 py-1 font-medium text-slate-700">
            Eligible customers: <%= unmappedMandates.totals.eligibleCustomers %>
          </span>
          <span class="rounded-full bg-amber-100 px-3 py-1 font-medium text-amber-800">
            Unmapped: <%= unmappedMandates.totals.unmappedCustomers %>
          </span>
          <span class="rounded-full bg-[#e6f4f3] px-3 py-1 font-medium text-[#087f7b]">
            Active unmapped: <%= unmappedMandates.totals.activeUnmappedCustomers %>
          </span>
        </div>
      </div>

      <% if (!runtimeConfig.goCardlessAccessTokenConfigured) { %>
        <div class="mt-4 text-sm text-slate-500">Configure the GoCardless token to scan unmapped mandates.</div>
      <% } else if (!unmappedMandates.items.length) { %>
        <div class="mt-4 rounded-lg border border-[#b6dcda] bg-[#e6f4f3] px-4 py-3 text-sm text-[#087f7b]">
          No unmapped eligible GoCardless mandates.
        </div>
      <% } else { %>
        <div class="mt-4 overflow-x-auto">
          <table class="min-w-full text-sm">
            <thead class="bg-[#f4f6f8] border-b border-[#dbe3ec]">
              <tr>
                <th class="px-3 py-2 text-left font-semibold">GoCardless Customer</th>
                <th class="px-3 py-2 text-left font-semibold">Mandates</th>
                <th class="px-3 py-2 text-left font-semibold">Halo/Xero Customer</th>
                <th class="px-3 py-2 text-right font-semibold">Action</th>
              </tr>
            </thead>
            <tbody>
              <% unmappedMandates.items.forEach(item => { %>
                <% const mapFormId = `map-${item.customerId}`; %>
                <tr class="border-b border-slate-100 align-top">
                  <td class="px-3 py-3">
                    <div class="font-medium"><%= item.customerName || item.customerId %></div>
                    <div class="mt-1 break-all text-xs text-slate-500">Customer ID: <%= item.customerId %></div>
                    <% if (item.email) { %>
                      <div class="break-all text-xs text-slate-500">Email: <%= item.email %></div>
                    <% } %>
                  </td>
                  <td class="px-3 py-3">
                    <div class="flex flex-wrap gap-2 text-xs">
                      <% Object.entries(item.mandateStatusCounts || {}).forEach(([status, count]) => { %>
                        <span class="rounded-full px-2 py-0.5 font-medium
                          <%= status === 'active' ? 'bg-[#e6f4f3] text-[#087f7b]' : '' %>
                          <%= ['pending_customer_approval', 'pending_submission', 'submitted'].includes(status) ? 'bg-amber-100 text-amber-800' : '' %>
                          <%= ['cancelled', 'failed', 'expired'].includes(status) ? 'bg-rose-100 text-rose-800' : '' %>
                          <%= !['active', 'pending_customer_approval', 'pending_submission', 'submitted', 'cancelled', 'failed', 'expired'].includes(status) ? 'bg-slate-100 text-slate-600' : '' %>">
                          <%= status.replaceAll("_", " ") %>: <%= count %>
                        </span>
                      <% }) %>
                    </div>
                  </td>
                  <td class="px-3 py-3">
                    <div class="space-y-2">
                      <% if (item.candidates.length) { %>
                        <select
                          form="<%= mapFormId %>"
                          name="xeroContactGuid"
                          class="w-full rounded-lg border border-[#dbe3ec] px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#087f7b]/20 focus:border-[#087f7b]"
                        >
                          <% if (item.candidates.length !== 1) { %>
                            <option value="">Select Halo/Xero customer...</option>
                          <% } %>
                          <% item.candidates.forEach(candidate => { %>
                            <option
                              value="<%= candidate.xeroContactGuid %>"
                              <%= item.suggestedXeroContactGuid === candidate.xeroContactGuid ? "selected" : "" %>
                            >
                              <%= candidate.haloClientName %><%= candidate.xeroContactNumber ? ` (${candidate.xeroContactNumber})` : "" %> - <%= candidate.sources.join(", ") %>
                            </option>
                          <% }) %>
                        </select>
                        <% if (item.candidates.length > 1) { %>
                          <div class="text-xs text-amber-700">Multiple candidates found. Select the correct Halo/Xero customer before mapping.</div>
                        <% } %>
                      <% } else { %>
                        <div class="text-xs text-slate-500">No safe candidate found.</div>
                      <% } %>

                      <input
                        form="<%= mapFormId %>"
                        name="manualXeroContactGuid"
                        placeholder="<%= item.candidates.length ? 'Or paste a different Xero Contact GUID' : 'Paste Xero Contact GUID' %>"
                        class="w-full rounded-lg border border-[#dbe3ec] px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#087f7b]/20 focus:border-[#087f7b]"
                      />
                      <% if (item.notes?.length) { %>
                        <div class="space-y-1">
                          <% item.notes.forEach(note => { %>
                            <div class="text-xs text-slate-500"><%= note %></div>
                          <% }) %>
                        </div>
                      <% } %>
                    </div>
                  </td>
                  <td class="px-3 py-3 text-right">
                    <form id="<%= mapFormId %>" method="POST" action="/admin/gocardless/map-now">
                      <input type="hidden" name="goCardlessCustomerId" value="<%= item.customerId %>" />
                      <input type="hidden" name="goCardlessCustomerName" value="<%= item.customerName || item.customerId %>" />
                      <button type="submit" class="rounded-full bg-[#087f7b] px-4 py-2 text-sm font-medium text-white hover:bg-[#066b68]">
                        Map Now
                      </button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6">
      <div class="bg-white rounded-lg shadow-sm border border-[#dbe3ec] p-5">
        <h2 class="text-xl font-semibold">Find Halo/Xero Client</h2>
        <form method="GET" action="/admin/gocardless" class="mt-4 flex gap-2">
          <input
            name="halo"
            value="<%= haloQuery %>"
            placeholder="Search Halo client, Xero name, or Xero GUID"
            class="min-w-0 flex-1 rounded-lg border border-[#dbe3ec] px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#087f7b]/20 focus:border-[#087f7b]"
          />
          <input type="hidden" name="gc" value="<%= goCardlessQuery %>" />
          <button class="rounded-full bg-[#087f7b] px-4 py-2 text-sm font-medium text-white hover:bg-[#066b68]">Search</button>
        </form>

        <div class="mt-4 space-y-2">
          <% if (haloMatches.length === 0 && haloQuery) { %>
            <div class="text-sm text-slate-500">No matching mapped Halo clients.</div>
          <% } %>
          <% haloMatches.forEach(client => { %>
            <div class="rounded-lg border border-[#dbe3ec] bg-[#fbfcfd] p-3 text-sm">
              <div class="font-medium"><%= client.halo_client_name %></div>
              <div class="text-xs text-slate-500 break-all">Xero GUID: <%= client.xero_contact_guid %></div>
              <% if (client.xero_contact_number) { %>
                <div class="text-xs text-slate-500">Xero contact number: <%= client.xero_contact_number %></div>
              <% } %>
            </div>
          <% }) %>
        </div>
      </div>

      <div class="bg-white rounded-lg shadow-sm border border-[#dbe3ec] p-5">
        <h2 class="text-xl font-semibold">Find GoCardless Customer</h2>
        <form method="GET" action="/admin/gocardless" class="mt-4 flex gap-2">
          <input type="hidden" name="halo" value="<%= haloQuery %>" />
          <input
            name="gc"
            value="<%= goCardlessQuery %>"
            placeholder="Search GoCardless name, email, ID, or metadata"
            class="min-w-0 flex-1 rounded-lg border border-[#dbe3ec] px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#087f7b]/20 focus:border-[#087f7b]"
          />
          <button class="rounded-full bg-[#087f7b] px-4 py-2 text-sm font-medium text-white hover:bg-[#066b68]">Search</button>
        </form>

        <div class="mt-4 space-y-2">
          <% if (!runtimeConfig.goCardlessAccessTokenConfigured) { %>
            <div class="text-sm text-slate-500">Configure the GoCardless token before searching.</div>
          <% } else if (goCardlessMatches.length === 0 && goCardlessQuery) { %>
            <div class="text-sm text-slate-500">No matching GoCardless customers.</div>
          <% } %>
          <% goCardlessMatches.forEach(customer => { %>
            <div class="rounded-lg border border-[#dbe3ec] bg-[#fbfcfd] p-3 text-sm">
              <div class="font-medium"><%= customer.name || customer.id %></div>
              <div class="text-xs text-slate-500 break-all">Customer ID: <%= customer.id %></div>
              <% if (customer.email) { %>
                <div class="text-xs text-slate-500 break-all">Email: <%= customer.email %></div>
              <% } %>
              <% if (Object.keys(customer.metadata || {}).length) { %>
                <div class="text-xs text-slate-500 break-all">
                  Metadata:
                  <% Object.entries(customer.metadata).forEach(([key, value], index) => { %>
                    <%= index ? " · " : "" %><%= key %>: <%= value %>
                  <% }) %>
                </div>
              <% } %>
              <% if (customer.mandateStatus) { %>
                <div class="mt-2 flex flex-wrap gap-2 text-xs">
                  <% Object.entries(customer.mandateStatus.counts || {}).forEach(([status, count]) => { %>
                    <span class="rounded-full px-2 py-0.5 font-medium
                      <%= status === 'active' ? 'bg-[#e6f4f3] text-[#087f7b]' : '' %>
                      <%= ['pending_customer_approval', 'pending_submission', 'submitted'].includes(status) ? 'bg-amber-100 text-amber-800' : '' %>
                      <%= ['cancelled', 'failed', 'expired'].includes(status) ? 'bg-rose-100 text-rose-800' : '' %>
                      <%= !['active', 'pending_customer_approval', 'pending_submission', 'submitted', 'cancelled', 'failed', 'expired'].includes(status) ? 'bg-slate-100 text-slate-600' : '' %>">
                      <%= status.replaceAll("_", " ") %>: <%= count %>
                    </span>
                  <% }) %>
                  <% if (!customer.mandateStatus.total) { %>
                    <span class="rounded-full bg-slate-100 px-2 py-0.5 font-medium text-slate-600">no mandates</span>
                  <% } %>
                </div>
              <% } %>
            </div>
          <% }) %>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow-sm border border-[#dbe3ec] p-5 mb-6">
      <div class="flex items-start justify-between gap-4 mb-4">
        <div>
          <h2 class="text-xl font-semibold">GoCardless Exceptions</h2>
          <p class="text-sm text-slate-500 mt-1">
            Failed payments, problem mandates, and duplicate-looking customer records.
          </p>
        </div>
        <a
          href="/admin/gocardless/exceptions"
          class="inline-flex shrink-0 rounded-full bg-[#087f7b] px-4 py-2 text-sm font-medium text-white hover:bg-[#066b68]"
        >
          View Exceptions
        </a>
      </div>
      <p class="text-sm text-slate-500">
        Opens a dedicated page and runs the latest exceptions scan on demand.
      </p>
    </div>

    <div class="bg-white rounded-lg shadow-sm border border-[#dbe3ec] p-5 mb-6">
      <h2 class="text-xl font-semibold">Add or Update Mapping</h2>
      <form method="POST" action="/admin/gocardless/mappings" class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-4">
        <label class="block">
          <span class="text-sm text-slate-500">Xero Contact GUID</span>
          <input name="xeroContactGuid" required placeholder="00000000-0000-0000-0000-000000000000" class="mt-1 w-full rounded-lg border border-[#dbe3ec] px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#087f7b]/20 focus:border-[#087f7b]" />
        </label>
        <label class="block">
          <span class="text-sm text-slate-500">GoCardless Customer ID</span>
          <input name="goCardlessCustomerId" required placeholder="CU..." class="mt-1 w-full rounded-lg border border-[#dbe3ec] px-3 py-2 text-sm uppercase focus:outline-none focus:ring-2 focus:ring-[#087f7b]/20 focus:border-[#087f7b]" />
        </label>
        <label class="block">
          <span class="text-sm text-slate-500">Display Name</span>
          <input name="haloClientName" placeholder="Optional label" class="mt-1 w-full rounded-lg border border-[#dbe3ec] px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#087f7b]/20 focus:border-[#087f7b]" />
        </label>
        <label class="block">
          <span class="text-sm text-slate-500">Notes</span>
          <input name="notes" placeholder="Optional" class="mt-1 w-full rounded-lg border border-[#dbe3ec] px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#087f7b]/20 focus:border-[#087f7b]" />
        </label>
        <div class="md:col-span-2 flex justify-end">
          <button type="submit" class="rounded-full bg-[#087f7b] px-4 py-2 text-sm font-medium text-white hover:bg-[#066b68]">
            Save Mapping
          </button>
        </div>
      </form>
    </div>

    <div class="bg-white rounded-lg shadow-sm border border-[#dbe3ec] p-5">
      <h2 class="text-xl font-semibold mb-4">Current Mappings</h2>
      <% if (mappings.length === 0) { %>
        <div class="text-sm text-slate-500">No GoCardless mappings have been added yet.</div>
      <% } else { %>
        <div class="overflow-x-auto">
          <table class="min-w-full text-sm">
            <thead class="bg-[#f4f6f8] border-b border-[#dbe3ec]">
              <tr>
                <th class="px-3 py-2 text-left font-semibold">Client</th>
                <th class="px-3 py-2 text-left font-semibold">Xero Contact GUID</th>
                <th class="px-3 py-2 text-left font-semibold">GoCardless ID</th>
                <th class="px-3 py-2 text-left font-semibold">Updated</th>
                <th class="px-3 py-2 text-right font-semibold">Action</th>
              </tr>
            </thead>
            <tbody>
              <% mappings.forEach(mapping => { %>
                <tr class="border-b border-slate-100">
                  <td class="px-3 py-2"><%= mapping.halo_client_name || "Unlabelled" %></td>
                  <td class="px-3 py-2 break-all text-xs text-slate-600"><%= mapping.xero_contact_guid %></td>
                  <td class="px-3 py-2 font-medium"><%= mapping.gocardless_customer_id %></td>
                  <td class="px-3 py-2 text-xs text-slate-500"><%= mapping.updated_at %></td>
                  <td class="px-3 py-2 text-right">
                    <form method="POST" action="/admin/gocardless/mappings/delete" onsubmit="return confirm('Remove this mapping?');">
                      <input type="hidden" name="xeroContactGuid" value="<%= mapping.xero_contact_guid %>" />
                      <button class="text-sm font-medium text-rose-700 hover:underline">Remove</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>
</body>
</html>
