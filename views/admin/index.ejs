<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Halo ↔ Xero Admin</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[#f3f6fa] min-h-screen p-6 text-[#0f172a]" style="font-family: Roboto, 'Segoe UI', Arial, sans-serif;">

  <div class="max-w-6xl mx-auto">
    <div class="mb-6 flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
      <div>
        <h1 class="text-[24px] font-semibold tracking-tight text-[#0f172a]">Halo ↔ Xero Admin Portal</h1>
        <p class="text-sm text-slate-500 mt-1">
          Operations dashboard for sync status, auth, exceptions, drift and reporting.
        </p>
      </div>

      <% if (currentAdmin) { %>
        <% const initials = currentAdmin.username.split(/[\s._@-]+/).filter(Boolean).slice(0, 2).map(part => part[0]).join("").toUpperCase() || "A"; %>
        <div class="flex items-center gap-3 rounded-lg border border-[#dbe3ec] bg-white px-4 py-3 shadow-sm">
          <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-[#087f7b] text-sm font-semibold text-white">
            <%= initials %>
          </div>
          <div class="min-w-0">
            <div class="max-w-[180px] truncate text-sm font-semibold"><%= currentAdmin.username %></div>
            <div class="mt-0.5 flex gap-3 text-xs">
              <a href="/admin/users" class="font-medium text-[#087f7b] hover:underline">Profile</a>
              <a href="/admin/logout" class="font-medium text-slate-500 hover:text-[#087f7b] hover:underline">Logout</a>
            </div>
          </div>
        </div>
      <% } %>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
      <div class="bg-white rounded-lg shadow-sm border border-[#dbe3ec] p-5">
        <div class="text-sm text-slate-500">Mapped Clients</div>
        <div class="text-3xl font-semibold mt-1 text-[#087f7b]"><%= mappedCount %></div>
      </div>

      <div class="bg-white rounded-lg shadow-sm border border-[#dbe3ec] p-5">
        <div class="text-sm text-slate-500">Last Sync Watermark</div>
        <div class="text-sm font-medium mt-2 break-all">
          <%= lastSyncHuman || "Not available" %>
        </div>
      </div>

      <div class="bg-white rounded-lg shadow-sm border border-[#dbe3ec] p-5">
        <div class="text-sm text-slate-500">Auth Mode</div>
        <div class="text-sm font-medium mt-2 break-all">
          Custom Connection
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
      <div class="bg-white rounded-lg shadow-sm border border-[#dbe3ec] p-5">
        <div class="text-sm text-slate-500 mb-2">Database Status</div>
        <span class="inline-flex px-3 py-1 rounded-full text-sm font-medium
          <%= dbStatus.state === 'ok' ? 'bg-[#e6f4f3] text-[#087f7b]' : '' %>
          <%= dbStatus.state === 'warn' ? 'bg-amber-100 text-amber-800' : '' %>
          <%= dbStatus.state === 'error' ? 'bg-rose-100 text-rose-800' : '' %>">
          <%= dbStatus.label %>
        </span>
      </div>

      <div class="bg-white rounded-lg shadow-sm border border-[#dbe3ec] p-5">
        <div class="text-sm text-slate-500 mb-2">Xero Auth Status</div>
        <span class="inline-flex px-3 py-1 rounded-full text-sm font-medium
          <%= authStatus.state === 'ok' ? 'bg-[#e6f4f3] text-[#087f7b]' : '' %>
          <%= authStatus.state === 'warn' ? 'bg-amber-100 text-amber-800' : '' %>
          <%= authStatus.state === 'error' ? 'bg-rose-100 text-rose-800' : '' %>">
          <%= authStatus.label %>
        </span>
        <div class="text-xs text-slate-500 mt-3">
          Tenant: <span class="font-medium"><%= tenantName || "Not available" %></span>
        </div>
      </div>

      <div class="bg-white rounded-lg shadow-sm border border-[#dbe3ec] p-5">
        <div class="text-sm text-slate-500 mb-2">Sync Status</div>
        <span class="inline-flex px-3 py-1 rounded-full text-sm font-medium
          <%= syncStatus.state === 'ok' ? 'bg-[#e6f4f3] text-[#087f7b]' : '' %>
          <%= syncStatus.state === 'warn' ? 'bg-amber-100 text-amber-800' : '' %>
          <%= syncStatus.state === 'error' ? 'bg-rose-100 text-rose-800' : '' %>">
          <%= syncStatus.label %>
        </span>
        <div class="text-xs text-slate-500 mt-3">
          Sync row updated: <span class="font-medium"><%= lastSyncUpdatedAt || "Not available" %></span>
        </div>
      </div>

      <div class="bg-white rounded-lg shadow-sm border border-[#dbe3ec] p-5">
        <div class="text-sm text-slate-500 mb-2">GoCardless Status</div>
        <span class="inline-flex px-3 py-1 rounded-full text-sm font-medium
          <%= goCardlessStatus.state === 'ok' ? 'bg-[#e6f4f3] text-[#087f7b]' : '' %>
          <%= goCardlessStatus.state === 'warn' ? 'bg-amber-100 text-amber-800' : '' %>
          <%= goCardlessStatus.state === 'error' ? 'bg-rose-100 text-rose-800' : '' %>">
          <%= goCardlessStatus.label %>
        </span>
        <div class="text-xs text-slate-500 mt-3">
          Token: <span class="font-medium"><%= runtimeConfig.goCardlessAccessTokenSource %></span>
        </div>
      </div>

      <div class="bg-white rounded-lg shadow-sm border border-[#dbe3ec] p-5">
        <div class="text-sm text-slate-500 mb-2">Halo API Status</div>
        <span class="inline-flex px-3 py-1 rounded-full text-sm font-medium
          <%= haloStatus.state === 'ok' ? 'bg-[#e6f4f3] text-[#087f7b]' : '' %>
          <%= haloStatus.state === 'warn' ? 'bg-amber-100 text-amber-800' : '' %>
          <%= haloStatus.state === 'error' ? 'bg-rose-100 text-rose-800' : '' %>">
          <%= haloStatus.label %>
        </span>
        <div class="text-xs text-slate-500 mt-3">
          Tenant: <span class="font-medium"><%= haloConfig.tenant || "Not available" %></span>
        </div>
        <div class="text-xs text-slate-500 mt-1">
          Client: <span class="font-medium"><%= haloConfig.clientIdSuffix ? `...${haloConfig.clientIdSuffix}` : "Not configured" %></span>
        </div>
      </div>
    </div>

    <div id="runtime-config" class="bg-white rounded-lg shadow-sm border border-[#dbe3ec] p-6 mb-6">
      <div class="flex items-start justify-between gap-4 mb-4">
        <div>
          <h2 class="text-xl font-semibold">Runtime Configuration</h2>
          <p class="text-sm text-slate-500 mt-1">
            Cache and export timing changes are applied from the admin override file without a restart.
          </p>
        </div>
        <span class="inline-flex px-3 py-1 rounded-full text-sm font-medium bg-[#e6f4f3] text-[#087f7b]">
          Editable
        </span>
      </div>

      <% if (flash?.success) { %>
        <div class="mb-4 rounded-lg border border-[#b6dcda] bg-[#e6f4f3] px-4 py-3 text-sm text-[#087f7b]">
          <%= flash.success %>
        </div>
      <% } %>

      <% if (flash?.error) { %>
        <div class="mb-4 rounded-lg border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-800">
          <%= flash.error %>
        </div>
      <% } %>

      <form method="POST" action="/admin/config/runtime">
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
          <label class="rounded-lg border border-[#dbe3ec] p-4 block bg-[#fbfcfd]">
            <span class="text-sm text-slate-500">Finance Cache TTL</span>
            <span class="block text-xs text-slate-500 mt-1">
              Current: <%= runtimeConfig.financeCacheTtlHuman %> · <%= runtimeConfig.financeCacheTtlSource %>
            </span>
            <input
              type="number"
              name="financeCacheTtlSeconds"
              min="<%= runtimeConfig.minTtlSeconds %>"
              max="<%= runtimeConfig.maxTtlSeconds %>"
              step="1"
              required
              value="<%= runtimeConfig.financeCacheTtlSeconds %>"
              class="mt-3 w-full rounded-lg border border-[#dbe3ec] px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#087f7b]/20 focus:border-[#087f7b]"
            />
            <span class="block text-xs text-slate-500 mt-2">
              Seconds. Used for finance-tab Xero invoice data.
            </span>
          </label>

          <label class="rounded-lg border border-[#dbe3ec] p-4 block bg-[#fbfcfd]">
            <span class="text-sm text-slate-500">Export Link TTL</span>
            <span class="block text-xs text-slate-500 mt-1">
              Current: <%= runtimeConfig.exportTokenTtlHuman %> · <%= runtimeConfig.exportTokenTtlSource %>
            </span>
            <input
              type="number"
              name="exportTokenTtlSeconds"
              min="<%= runtimeConfig.minTtlSeconds %>"
              max="<%= runtimeConfig.maxTtlSeconds %>"
              step="1"
              required
              value="<%= runtimeConfig.exportTokenTtlSeconds %>"
              class="mt-3 w-full rounded-lg border border-[#dbe3ec] px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#087f7b]/20 focus:border-[#087f7b]"
            />
            <span class="block text-xs text-slate-500 mt-2">
              Seconds. Used for newly generated PDF and Excel links.
            </span>
          </label>

          <label class="rounded-lg border border-[#dbe3ec] p-4 block bg-[#fbfcfd]">
            <span class="text-sm text-slate-500">GoCardless Auto-map Interval</span>
            <span class="block text-xs text-slate-500 mt-1">
              Current: <%= runtimeConfig.goCardlessAutoMapIntervalHuman %> · <%= runtimeConfig.goCardlessAutoMapIntervalSource %>
            </span>
            <input
              type="number"
              name="goCardlessAutoMapIntervalSeconds"
              min="<%= runtimeConfig.minTtlSeconds %>"
              max="<%= runtimeConfig.maxTtlSeconds %>"
              step="1"
              required
              value="<%= runtimeConfig.goCardlessAutoMapIntervalSeconds %>"
              class="mt-3 w-full rounded-lg border border-[#dbe3ec] px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#087f7b]/20 focus:border-[#087f7b]"
            />
            <span class="block text-xs text-slate-500 mt-2">
              Seconds. Scans active mandates and creates safe missing mappings.
            </span>
          </label>

          <div class="rounded-lg border border-[#dbe3ec] p-4 bg-[#fbfcfd]">
            <div class="text-sm text-slate-500">Export Token Secret</div>
            <div class="text-sm font-semibold mt-2">
              <%= runtimeConfig.exportTokenSecretSource %>
            </div>
            <div class="text-xs text-slate-500 mt-3">
              <%= runtimeConfig.exportTokenSecretConfigured ? "Dedicated export token secret is configured." : "Using HMAC_SECRET until EXPORT_TOKEN_SECRET is set." %>
            </div>
            <div class="text-xs text-slate-500 mt-3 break-all">
              Override file: <%= runtimeConfig.configPath %>
            </div>
          </div>
        </div>

        <div class="mt-4 flex items-center justify-between gap-4">
          <div class="text-xs text-slate-500">
            Allowed range: <%= runtimeConfig.minTtlSeconds %> to <%= runtimeConfig.maxTtlSeconds %> seconds.
          </div>
          <button
            type="submit"
            class="inline-flex px-4 py-2 rounded-full bg-[#087f7b] text-white text-sm font-medium hover:bg-[#066b68]"
          >
            Save Runtime Settings
          </button>
        </div>
      </form>
    </div>

    <div class="bg-white rounded-lg shadow-sm border border-[#dbe3ec] p-6 mb-6">
      <h2 class="text-xl font-semibold mb-4">Actions</h2>

      <div class="space-y-6">
        <section>
          <div class="mb-3">
            <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-500">API Connections</h3>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
            <a
              href="/admin/PSA"
              class="block p-4 rounded-lg bg-white hover:bg-[#f6fbfb] border border-[#dbe3ec] transition"
            >
              <div class="font-semibold">Halo API</div>
              <div class="text-sm text-slate-600 mt-1">
                Configure PSA API access and Direct Debit field sync.
              </div>
            </a>

            <a
              href="/admin/gocardless"
              class="block p-4 rounded-lg bg-white hover:bg-[#f6fbfb] border border-[#dbe3ec] transition"
            >
              <div class="font-semibold">GoCardless Settings</div>
              <div class="text-sm text-slate-600 mt-1">
                Manage the API token and Xero GUID customer mappings.
              </div>
            </a>

            <a
              href="/admin/xero/connect"
              class="block p-4 rounded-lg bg-white hover:bg-[#f6fbfb] border border-[#dbe3ec] transition"
            >
              <div class="font-semibold">Test Xero Connection</div>
              <div class="text-sm text-slate-600 mt-1">
                Validate the Custom Connection credentials.
              </div>
            </a>
          </div>
        </section>

        <section>
          <div class="mb-3">
            <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-500">Sync and Data</h3>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
            <form method="POST" action="/admin/sync">
              <button
                type="submit"
                class="w-full text-left p-4 rounded-lg bg-[#e6f4f3] hover:bg-[#d9eeed] border border-[#b6dcda] transition"
              >
                <div class="font-semibold">Run Sync Now</div>
                <div class="text-sm text-slate-600 mt-1">
                  Trigger an immediate delta sync from Xero.
                </div>
              </button>
            </form>

            <form method="POST" action="/admin/sync/full" onsubmit="return confirm('Are you sure you want to run a full resync? This will reset the sync watermark and may take longer.');">
              <button
                type="submit"
                class="w-full text-left p-4 rounded-lg bg-[#fff1f1] hover:bg-[#ffe7e7] border border-[#f3c5c7] transition"
              >
                <div class="font-semibold">Full Resync</div>
                <div class="text-sm text-slate-600 mt-1">
                  Reset watermark and rebuild contact sync from Xero.
                </div>
              </button>
            </form>

            <a
              href="/admin/exceptions"
              class="block p-4 rounded-lg bg-white hover:bg-[#f6fbfb] border border-[#dbe3ec] transition"
            >
              <div class="font-semibold">Mapping Exceptions</div>
              <div class="text-sm text-slate-600 mt-1">
                Review clients without valid Xero mappings.
              </div>
            </a>

            <a
              href="/admin/drift"
              class="block p-4 rounded-lg bg-white hover:bg-[#f6fbfb] border border-[#dbe3ec] transition"
            >
              <div class="font-semibold">Name Drift Report</div>
              <div class="text-sm text-slate-600 mt-1">
                Review detected differences between Halo and Xero naming.
              </div>
            </a>

            <a
              href="/admin/metrics"
              class="block p-4 rounded-lg bg-white hover:bg-[#f6fbfb] border border-[#dbe3ec] transition"
            >
              <div class="font-semibold">Growth Metrics</div>
              <div class="text-sm text-slate-600 mt-1">
                View Xero customer growth and sync counts over time.
              </div>
            </a>
          </div>
        </section>

        <section>
          <div class="mb-3">
            <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-500">Operations</h3>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
            <a
              href="/admin/health"
              class="block p-4 rounded-lg bg-white hover:bg-[#f6fbfb] border border-[#dbe3ec] transition"
            >
              <div class="font-semibold">Health Check</div>
              <div class="text-sm text-slate-600 mt-1">
                Review integration status in a readable dashboard.
              </div>
            </a>

            <a
              href="/admin/logs?source=all"
              class="block p-4 rounded-lg bg-white hover:bg-[#f6fbfb] border border-[#dbe3ec] transition"
            >
              <div class="font-semibold">View Logs</div>
              <div class="text-sm text-slate-600 mt-1">
                Show recent warning and error lines.
              </div>
            </a>

            <a
              href="/admin/alerts"
              class="block p-4 rounded-lg bg-white hover:bg-[#f6fbfb] border border-[#dbe3ec] transition"
            >
              <div class="font-semibold">Alerts</div>
              <div class="text-sm text-slate-600 mt-1">
                Configure Teams alerts and send a test notification.
              </div>
            </a>

            <a
              href="/admin/users"
              class="block p-4 rounded-lg bg-white hover:bg-[#f6fbfb] border border-[#dbe3ec] transition"
            >
              <div class="font-semibold">Admin Users</div>
              <div class="text-sm text-slate-600 mt-1">
                Manage accounts, lockouts, and login audit history.
              </div>
            </a>

            <a
              href="/admin/logout"
              class="block p-4 rounded-lg bg-white hover:bg-[#f6fbfb] border border-[#dbe3ec] transition"
            >
              <div class="font-semibold">Logout</div>
              <div class="text-sm text-slate-600 mt-1">
                End the current admin session.
              </div>
            </a>
          </div>
        </section>
      </div>
    </div>

    <div class="text-xs text-slate-500">
      Admin URL: <span class="font-medium">https://widget.example.com/admin</span>
    </div>
  </div>

</body>
</html>
