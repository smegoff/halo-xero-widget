<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Alerts</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[#f3f6fa] min-h-screen p-6 text-[#0f172a]" style="font-family: Roboto, 'Segoe UI', Arial, sans-serif;">
  <div class="max-w-5xl mx-auto">
    <div class="mb-6 flex items-start justify-between gap-4">
      <div>
        <h1 class="text-[24px] font-semibold tracking-tight">Alerts</h1>
        <p class="text-sm text-slate-500 mt-1">
          Send operational alerts to Microsoft Teams using an incoming webhook or workflow webhook URL.
        </p>
      </div>
      <a href="/admin" class="inline-flex px-4 py-2 rounded-full bg-white border border-[#dbe3ec] text-sm font-medium hover:bg-[#f6fbfb]">
        Back to Admin
      </a>
    </div>

    <% if (flash?.success) { %>
      <div class="mb-4 rounded-lg border border-[#b6dcda] bg-[#e6f4f3] px-4 py-3 text-sm text-[#087f7b]">
        <%= flash.success %>
      </div>
    <% } %>

    <% if (flash?.error) { %>
      <div class="mb-4 rounded-lg border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-800">
        <%= flash.error %>
      </div>
    <% } %>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 mb-6">
      <div class="bg-white rounded-lg shadow-sm border border-[#dbe3ec] p-5 lg:col-span-2">
        <div class="flex items-start justify-between gap-4 mb-4">
          <div>
            <h2 class="text-xl font-semibold">Teams Webhook</h2>
            <p class="text-sm text-slate-500 mt-1">
              The webhook URL is never displayed after saving.
            </p>
          </div>
          <span class="inline-flex px-3 py-1 rounded-full text-sm font-medium
            <%= alertSettings.enabled && alertSettings.teamsConfigured ? 'bg-[#e6f4f3] text-[#087f7b]' : 'bg-amber-100 text-amber-800' %>">
            <%= alertSettings.enabled && alertSettings.teamsConfigured ? 'Enabled' : 'Not Active' %>
          </span>
        </div>

        <form method="POST" action="/admin/alerts/config" class="space-y-4">
          <label class="flex items-center gap-3 rounded-lg border border-[#dbe3ec] bg-[#fbfcfd] p-4">
            <input
              type="checkbox"
              name="alertsEnabled"
              value="true"
              <%= alertSettings.enabled ? "checked" : "" %>
              class="h-4 w-4 rounded border-[#dbe3ec] text-[#087f7b] focus:ring-[#087f7b]"
            />
            <span>
              <span class="block text-sm font-medium">Enable alerts</span>
              <span class="block text-xs text-slate-500">Source: <%= alertSettings.enabledSource %></span>
            </span>
          </label>

          <label class="block rounded-lg border border-[#dbe3ec] bg-[#fbfcfd] p-4">
            <span class="text-sm text-slate-500">Teams Webhook URL</span>
            <span class="block text-xs text-slate-500 mt-1">
              <%= alertSettings.teamsConfigured ? `Configured via ${alertSettings.teamsWebhookUrlSource}` : "Not configured" %>
            </span>
            <input
              type="password"
              name="teamsWebhookUrl"
              autocomplete="new-password"
              placeholder="Leave blank to keep current webhook URL"
              class="mt-3 w-full rounded-lg border border-[#dbe3ec] px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#087f7b]/20 focus:border-[#087f7b]"
            />
          </label>

          <div class="flex flex-wrap items-center justify-between gap-3">
            <div class="text-xs text-slate-500 break-all">
              Override file: <%= alertSettings.configPath %>
              <% if (alertSettings.updatedAt) { %>
                · Updated: <%= alertSettings.updatedAt %>
              <% } %>
            </div>
            <button type="submit" class="inline-flex rounded-full bg-[#087f7b] px-4 py-2 text-sm font-medium text-white hover:bg-[#066b68]">
              Save Alert Settings
            </button>
          </div>
        </form>

        <form method="POST" action="/admin/alerts/config/clear" class="mt-4" onsubmit="return confirm('Clear the alert admin override and fall back to .env values?');">
          <button type="submit" class="text-sm font-medium text-rose-700 hover:underline">
            Clear Admin Override
          </button>
        </form>
      </div>

      <div class="bg-white rounded-lg shadow-sm border border-[#dbe3ec] p-5">
        <h2 class="text-xl font-semibold mb-4">Test</h2>
        <p class="text-sm text-slate-500">
          Sends a sample Adaptive Card to the configured Teams destination.
        </p>
        <form method="POST" action="/admin/alerts/test" class="mt-4">
          <button type="submit" class="inline-flex w-full justify-center rounded-full bg-[#087f7b] px-4 py-2 text-sm font-medium text-white hover:bg-[#066b68]">
            Send Test Alert
          </button>
        </form>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow-sm border border-[#dbe3ec] p-5">
      <h2 class="text-xl font-semibold mb-3">Alert Events</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
        <div class="rounded-lg border border-[#dbe3ec] bg-[#fbfcfd] p-4">
          <div class="font-semibold">Security</div>
          <div class="mt-1 text-slate-600">Admin account lockout after repeated failed login attempts.</div>
        </div>
        <div class="rounded-lg border border-[#dbe3ec] bg-[#fbfcfd] p-4">
          <div class="font-semibold">Sync Failures</div>
          <div class="mt-1 text-slate-600">Manual Xero sync, full resync, GoCardless auto-map, and Halo Direct Debit sync failures.</div>
        </div>
        <div class="rounded-lg border border-[#dbe3ec] bg-[#fbfcfd] p-4">
          <div class="font-semibold">Scheduled Jobs</div>
          <div class="mt-1 text-slate-600">Scheduled GoCardless auto-map and Direct Debit custom-field sync failures.</div>
        </div>
        <div class="rounded-lg border border-[#dbe3ec] bg-[#fbfcfd] p-4">
          <div class="font-semibold">Service Health</div>
          <div class="mt-1 text-slate-600">PM2 service status, stale Xero contact sync, and recent failed GoCardless webhook processing.</div>
        </div>
        <div class="rounded-lg border border-[#dbe3ec] bg-[#fbfcfd] p-4">
          <div class="font-semibold">Noise Control</div>
          <div class="mt-1 text-slate-600">Routine successful jobs do not send alerts.</div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
