<!DOCTYPE html>
<%
  const rows = Array.isArray(data) ? data : [];
  const selectedRange = filter?.range || "30d";
  const numberFormat = new Intl.NumberFormat("en-NZ");
  const percentFormat = new Intl.NumberFormat("en-NZ", {
    minimumFractionDigits: 1,
    maximumFractionDigits: 1
  });
  const dateTimeFormat = new Intl.DateTimeFormat("en-NZ", {
    dateStyle: "medium",
    timeStyle: "short"
  });
  const shortDateFormat = new Intl.DateTimeFormat("en-NZ", {
    dateStyle: "medium"
  });
  const formatDateTime = value => value ? dateTimeFormat.format(new Date(value)) : "No data";
  const formatShortDate = value => value ? shortDateFormat.format(new Date(value)) : "No data";
  const formatNumber = value => value === null || value === undefined ? "No data" : numberFormat.format(value);
  const formatPercent = value => value === null || value === undefined ? "No data" : `${percentFormat.format(value)}%`;
  const formatDelta = value => {
    if (value === null || value === undefined) return "No data";
    if (Number(value) === 0) return "No change";
    return `${Number(value) > 0 ? "+" : ""}${numberFormat.format(value)}`;
  };
  const recentRows = rows.slice(-25).reverse();
  const hasRows = rows.length > 0;
  const hitSampleLimit = rows.length >= maxSamples;
%>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Halo Xero Metrics</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body class="bg-[#f3f6fa] min-h-screen p-4 text-[#0f172a] md:p-6" style="font-family: Roboto, 'Segoe UI', Arial, sans-serif;">

  <main class="mx-auto max-w-7xl">
    <header class="mb-5 flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
      <div>
        <h1 class="text-[24px] font-semibold tracking-tight">Growth Metrics</h1>
        <p class="mt-1 text-sm text-slate-500">
          Xero customer growth and mapped contact totals by recorded sync snapshot.
        </p>
      </div>
      <a href="/admin" class="inline-flex w-fit items-center rounded-full border border-[#dbe3ec] bg-white px-4 py-2 text-sm font-medium shadow-sm hover:bg-[#f6fbfb]">
        Back to Admin
      </a>
    </header>

    <section class="mb-5 rounded-lg border border-[#dbe3ec] bg-white p-4 shadow-sm">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <div class="text-xs font-semibold uppercase tracking-[0.08em] text-[#087f7b]">Date Range</div>
          <div class="mt-2 flex flex-wrap gap-2">
            <% presets.forEach(preset => { %>
              <a
                href="/admin/metrics?range=<%= preset.value %>"
                class="rounded-full border px-3 py-2 text-sm font-medium <%= selectedRange === preset.value ? 'border-[#087f7b] bg-[#087f7b] text-white shadow-sm' : 'border-[#dbe3ec] bg-[#fbfcfd] text-slate-700 hover:bg-[#eef8f7]' %>"
              >
                <%= preset.label %>
              </a>
            <% }) %>
          </div>
        </div>

        <form method="get" action="/admin/metrics" class="grid grid-cols-1 gap-3 sm:grid-cols-[minmax(0,1fr)_minmax(0,1fr)_auto]">
          <input type="hidden" name="range" value="custom" />
          <label class="text-sm font-medium text-slate-700">
            From
            <input
              type="date"
              name="from"
              value="<%= filter.from || '' %>"
              class="mt-1 block w-full rounded-md border border-[#dbe3ec] bg-white px-3 py-2 text-sm outline-none focus:border-[#087f7b] focus:ring-2 focus:ring-[#087f7b]/20"
            />
          </label>
          <label class="text-sm font-medium text-slate-700">
            To
            <input
              type="date"
              name="to"
              value="<%= filter.to || '' %>"
              class="mt-1 block w-full rounded-md border border-[#dbe3ec] bg-white px-3 py-2 text-sm outline-none focus:border-[#087f7b] focus:ring-2 focus:ring-[#087f7b]/20"
            />
          </label>
          <button type="submit" class="self-end rounded-full bg-[#087f7b] px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-[#066d6a]">
            Apply
          </button>
        </form>
      </div>

      <% if (filter.error) { %>
        <div class="mt-4 rounded-md border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900">
          <%= filter.error %>
        </div>
      <% } %>

      <div class="mt-4 flex flex-col gap-2 border-t border-[#edf1f5] pt-4 text-sm text-slate-500 md:flex-row md:items-center md:justify-between">
        <div>
          Showing <span class="font-medium text-slate-700"><%= filter.label %></span>
          <% if (filter.from || filter.to) { %>
            from <span class="font-medium text-slate-700"><%= filter.from || 'first sample' %></span>
            to <span class="font-medium text-slate-700"><%= filter.to || 'latest sample' %></span>.
          <% } %>
        </div>
        <div>
          Overall history:
          <span class="font-medium text-slate-700"><%= formatNumber(allStats.total_samples) %></span> samples,
          <span class="font-medium text-slate-700"><%= formatShortDate(allStats.first_recorded_at) %></span>
          to
          <span class="font-medium text-slate-700"><%= formatShortDate(allStats.latest_recorded_at) %></span>.
          Chart granularity:
          <span class="font-medium text-slate-700"><%= bucket.label %></span>.
        </div>
      </div>
    </section>

    <% if (!hasRows) { %>
      <section class="rounded-lg border border-[#dbe3ec] bg-white p-10 text-center shadow-sm">
        <div class="text-xl font-semibold text-slate-700">No metrics in this date range</div>
        <p class="mx-auto mt-2 max-w-xl text-sm text-slate-500">
          Try a wider range or run a Xero contact sync so a fresh metrics snapshot is written.
        </p>
        <div class="mt-5">
          <a href="/admin/metrics?range=all" class="inline-flex rounded-full bg-[#087f7b] px-4 py-2 text-sm font-semibold text-white hover:bg-[#066d6a]">
            Show All Time
          </a>
        </div>
      </section>
    <% } else { %>
      <section class="mb-5 grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-4">
        <div class="rounded-lg border border-[#dbe3ec] bg-white p-4 shadow-sm">
          <div class="text-sm text-slate-500">Chart Data Points</div>
          <div class="mt-1 text-2xl font-semibold text-[#087f7b]"><%= formatNumber(summary.samples) %></div>
          <div class="mt-2 text-xs text-slate-500"><%= formatNumber(summary.rawSamples) %> snapshots reduced to <%= bucket.label.toLowerCase() %> points</div>
        </div>

        <div class="rounded-lg border border-[#cbe6e4] bg-[#edf8f7] p-4 shadow-sm">
          <div class="text-sm text-slate-600">Latest Total Clients</div>
          <div class="mt-1 text-2xl font-semibold text-[#075f5c]"><%= formatNumber(summary.latestTotalClients) %></div>
          <div class="mt-2 text-xs font-medium text-[#087f7b]"><%= formatDelta(summary.totalClientDelta) %> across range</div>
        </div>

        <div class="rounded-lg border border-[#dbe3ec] bg-white p-4 shadow-sm">
          <div class="text-sm text-slate-500">Latest Mapped Clients</div>
          <div class="mt-1 text-2xl font-semibold text-[#0f172a]"><%= formatNumber(summary.latestMappedClients) %></div>
          <div class="mt-2 text-xs font-medium text-slate-600"><%= formatDelta(summary.mappedClientDelta) %> across range</div>
        </div>

        <div class="rounded-lg border border-[#bfd5ff] bg-[#eef4ff] p-4 shadow-sm">
          <div class="text-sm text-slate-600">Mapped Coverage</div>
          <div class="mt-1 text-2xl font-semibold text-[#1d4ed8]"><%= formatPercent(summary.latestMappedPercent) %></div>
          <div class="mt-2 text-xs text-slate-500">Latest mapped clients divided by latest total clients</div>
        </div>
      </section>

      <% if (hitSampleLimit) { %>
        <div class="mb-5 rounded-md border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900">
          This range hit the <%= formatNumber(maxSamples) %> sample display limit. Narrow the date range if the latest trend needs more detail.
        </div>
      <% } %>

      <section class="mb-5 rounded-lg border border-[#dbe3ec] bg-white p-4 shadow-sm">
        <div class="mb-3 flex flex-col gap-1 md:flex-row md:items-baseline md:justify-between">
          <h2 class="text-lg font-semibold">Client Growth Trend</h2>
          <p class="text-sm text-slate-500">Latest sync snapshot per <%= bucket.label.toLowerCase() %> bucket.</p>
        </div>
        <div class="h-[360px] rounded-md border border-[#edf1f5] bg-[#fbfcfd] p-3">
          <canvas id="metricsChart"></canvas>
        </div>
      </section>

      <section class="rounded-lg border border-[#dbe3ec] bg-white shadow-sm">
        <div class="border-b border-[#edf1f5] px-4 py-3">
          <h2 class="text-lg font-semibold">Recent Data Points</h2>
          <p class="mt-1 text-sm text-slate-500">Latest 25 <%= bucket.label.toLowerCase() %> points from this range.</p>
        </div>
        <div class="overflow-x-auto">
          <table class="min-w-full text-left text-sm">
            <thead class="bg-[#f7f9fb] text-xs uppercase tracking-[0.06em] text-slate-500">
              <tr>
                <th class="px-4 py-3 font-semibold">Recorded</th>
                <th class="px-4 py-3 font-semibold">Total Clients</th>
                <th class="px-4 py-3 font-semibold">Mapped Clients</th>
                <th class="px-4 py-3 font-semibold">Mapped Coverage</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-[#edf1f5]">
              <% recentRows.forEach(row => {
                const total = Number(row.total_clients || 0);
                const mapped = Number(row.mapped_clients || 0);
                const coverage = total > 0 ? (mapped / total) * 100 : null;
              %>
                <tr>
                  <td class="whitespace-nowrap px-4 py-3 text-slate-700"><%= formatDateTime(row.recorded_at) %></td>
                  <td class="whitespace-nowrap px-4 py-3 font-medium"><%= formatNumber(total) %></td>
                  <td class="whitespace-nowrap px-4 py-3"><%= formatNumber(mapped) %></td>
                  <td class="whitespace-nowrap px-4 py-3 text-[#1d4ed8]"><%= formatPercent(coverage) %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>
    <% } %>
  </main>

  <% if (hasRows) { %>
  <script>
    const raw = <%- JSON.stringify(rows) %>;

    const labels = raw.map(row =>
      new Date(row.recorded_at).toLocaleString('en-NZ', {
        day: '2-digit',
        month: 'short',
        year: 'numeric',
        hour: '2-digit',
        minute: '2-digit'
      })
    );

    const totalClients = raw.map(row => Number(row.total_clients || 0));
    const mappedClients = raw.map(row => Number(row.mapped_clients || 0));
    const ctx = document.getElementById('metricsChart');

    new Chart(ctx, {
      type: 'line',
      data: {
        labels,
        datasets: [
          {
            label: 'Total Clients',
            data: totalClients,
            borderColor: '#087f7b',
            backgroundColor: 'rgba(8, 127, 123, 0.12)',
            pointRadius: raw.length > 60 ? 0 : 3,
            pointHoverRadius: 5,
            borderWidth: 2,
            tension: 0.22
          },
          {
            label: 'Mapped Clients',
            data: mappedClients,
            borderColor: '#1d4ed8',
            backgroundColor: 'rgba(29, 78, 216, 0.12)',
            pointRadius: raw.length > 60 ? 0 : 3,
            pointHoverRadius: 5,
            borderWidth: 2,
            tension: 0.22
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: {
          mode: 'index',
          intersect: false
        },
        plugins: {
          legend: {
            position: 'top',
            labels: {
              usePointStyle: true,
              boxWidth: 8,
              boxHeight: 8
            }
          },
          tooltip: {
            callbacks: {
              label(context) {
                return `${context.dataset.label}: ${Number(context.raw || 0).toLocaleString('en-NZ')}`;
              }
            }
          }
        },
        scales: {
          x: {
            grid: {
              display: false
            },
            ticks: {
              maxRotation: 0,
              autoSkip: true,
              maxTicksLimit: 8
            }
          },
          y: {
            beginAtZero: false,
            ticks: {
              precision: 0
            },
            grid: {
              color: '#edf1f5'
            }
          }
        }
      }
    });
  </script>
  <% } %>

</body>
</html>
