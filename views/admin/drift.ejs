<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Name Drift</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[#f3f6fa] text-[#0f172a] min-h-screen p-6" style="font-family: Roboto, 'Segoe UI', Arial, sans-serif;">

<div class="max-w-6xl mx-auto p-6 bg-white rounded-lg shadow-sm border border-[#dbe3ec]">

  <h1 class="text-[24px] font-semibold mb-4">
    Name Drift Detected
  </h1>

  <p class="text-slate-600 mb-6">
    These clients are mapped by GUID, but the Halo name no longer matches
    the live Xero contact name.
  </p>

  <div class="mb-6 p-4 bg-amber-50 border border-amber-200 rounded-lg">
    <div class="text-sm text-gray-500">Drifted Clients</div>
    <div class="text-xl font-semibold text-yellow-700">
      <%= driftCount %>
    </div>
  </div>

  <% if (drifted.length === 0) { %>
    <div class="p-4 bg-[#e6f4f3] border border-[#b6dcda] rounded-lg text-[#087f7b]">
      No name drift detected.
    </div>
  <% } else { %>
    <div class="overflow-x-auto rounded-lg border border-[#dbe3ec]">
    <table class="w-full border-collapse">
      <thead class="bg-[#f4f6f8]">
        <tr class="border-b border-[#dbe3ec]">
          <th class="text-left py-2.5 px-3 text-sm font-semibold">Halo Name</th>
          <th class="text-left py-2.5 px-3 text-sm font-semibold">Xero Name (Live)</th>
          <th class="text-left py-2.5 px-3 text-sm font-semibold">Contact GUID</th>
        </tr>
      </thead>
      <tbody>
        <% drifted.forEach(d => { %>
          <tr class="border-b border-slate-100 hover:bg-[#f7fafc]">
            <td class="py-2.5 px-3 font-medium"><%= d.haloClientName %></td>
            <td class="py-2.5 px-3 text-amber-700"><%= d.xeroClientName %></td>
            <td class="py-2.5 px-3 text-xs text-slate-500"><%= d.contactGuid %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    </div>
  <% } %>

  <div class="mt-6 flex gap-4">
    <a href="/admin" class="text-[#087f7b] hover:underline font-medium">
      ← Admin Home
    </a>
    <a href="/admin/exceptions" class="text-[#087f7b] hover:underline font-medium">
      View Exceptions
    </a>
  </div>

</div>

</body>
</html>
