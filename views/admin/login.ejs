<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Admin Login</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[#f3f6fa] min-h-screen flex items-center justify-center text-[#0f172a]" style="font-family: Inter, 'Segoe UI', Arial, sans-serif;">

  <div class="bg-white p-8 rounded-lg shadow-sm border border-[#dbe3ec] w-full max-w-sm">
    <h1 class="text-2xl font-semibold mb-6 text-center text-[#087f7b]">
      Halo ↔ Xero Admin
    </h1>

    <% if (typeof error !== "undefined" && error) { %>
      <div class="mb-4 text-sm text-red-700 bg-red-50 border border-red-200 p-2 rounded">
        <%= error %>
      </div>
    <% } %>

    <form method="POST" action="/admin/login" class="space-y-4">

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Username
        </label>
        <input
          type="text"
          name="username"
          required
          class="w-full rounded-lg border border-[#dbe3ec] bg-white px-3 py-2
                 shadow-sm
                 focus:outline-none focus:ring-2 focus:ring-[#087f7b]/20 focus:border-[#087f7b]"
        />
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Password
        </label>
        <input
          type="password"
          name="password"
          required
          class="w-full rounded-lg border border-[#dbe3ec] bg-white px-3 py-2
                 shadow-sm
                 focus:outline-none focus:ring-2 focus:ring-[#087f7b]/20 focus:border-[#087f7b]"
        />
      </div>

      <button
        type="submit"
        class="w-full bg-[#087f7b] text-white py-2 rounded-full
               hover:bg-[#066b68] transition font-medium"
      >
        Login
      </button>

    </form>
  </div>

</body>
</html>
