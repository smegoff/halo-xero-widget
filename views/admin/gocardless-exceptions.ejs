<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>GoCardless Exceptions</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[#f3f6fa] min-h-screen p-6 text-[#0f172a]" style="font-family: Roboto, 'Segoe UI', Arial, sans-serif;">
  <div class="max-w-6xl mx-auto">
    <div class="mb-6 flex items-start justify-between gap-4">
      <div>
        <h1 class="text-[24px] font-semibold tracking-tight">GoCardless Exceptions</h1>
        <p class="text-sm text-slate-500 mt-1">
          Failed payments, problem mandates, and duplicate-looking customer records.
        </p>
      </div>
      <div class="flex flex-wrap justify-end gap-2">
        <a href="/admin/gocardless/exceptions" class="inline-flex px-4 py-2 rounded-full bg-[#087f7b] text-white text-sm font-medium hover:bg-[#066b68]">
          Refresh
        </a>
        <a href="/admin/gocardless" class="inline-flex px-4 py-2 rounded-full bg-white border border-[#dbe3ec] text-sm font-medium hover:bg-[#f6fbfb]">
          Back to GoCardless
        </a>
      </div>
    </div>

    <% if (flash?.success) { %>
      <div class="mb-4 rounded-lg border border-[#b6dcda] bg-[#e6f4f3] px-4 py-3 text-sm text-[#087f7b]">
        <%= flash.success %>
      </div>
    <% } %>

    <% if (flash?.error) { %>
      <div class="mb-4 rounded-lg border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-800">
        <%= flash.error %>
      </div>
    <% } %>

    <div class="bg-white rounded-lg shadow-sm border border-[#dbe3ec] p-5">
      <% if (!goCardlessAnomalies?.configured) { %>
        <div class="text-sm text-slate-500">Configure the GoCardless token to load exceptions.</div>
      <% } else { %>
        <div class="grid grid-cols-1 xl:grid-cols-3 gap-4">
          <div class="rounded-lg border border-[#dbe3ec] bg-[#fbfcfd] p-4">
            <h2 class="font-semibold text-sm mb-3">Problem Payments</h2>
            <% if (!goCardlessAnomalies.problemPayments.length) { %>
              <div class="text-sm text-slate-500">No failed or cancelled payments found in the latest scan.</div>
            <% } %>
            <div class="space-y-2">
              <% goCardlessAnomalies.problemPayments.forEach(item => { %>
                <div class="rounded-md border border-rose-100 bg-white p-3 text-xs">
                  <div class="flex items-center justify-between gap-2">
                    <span class="font-semibold text-rose-700"><%= item.statusLabel %></span>
                    <span class="text-slate-500"><%= item.date || "No date" %></span>
                  </div>
                  <div class="mt-1 break-all text-slate-600">Payment: <%= item.paymentId %></div>
                  <% if (item.customerId) { %>
                    <div class="break-all text-slate-500">Customer: <%= item.customerId %></div>
                  <% } %>
                </div>
              <% }) %>
            </div>
          </div>

          <div class="rounded-lg border border-[#dbe3ec] bg-[#fbfcfd] p-4">
            <h2 class="font-semibold text-sm mb-3">Problem Mandates</h2>
            <% if (!goCardlessAnomalies.problemMandates.length) { %>
              <div class="text-sm text-slate-500">No failed, expired, or cancelled mandates found in the latest scan.</div>
            <% } %>
            <div class="space-y-2">
              <% goCardlessAnomalies.problemMandates.forEach(item => { %>
                <div class="rounded-md border border-amber-100 bg-white p-3 text-xs">
                  <div class="flex items-center justify-between gap-2">
                    <span class="font-semibold <%= item.severity === 'error' ? 'text-rose-700' : 'text-amber-800' %>"><%= item.statusLabel %></span>
                    <span class="text-slate-500"><%= item.date || "No date" %></span>
                  </div>
                  <div class="mt-1 break-all text-slate-600">Mandate: <%= item.mandateId %></div>
                  <% if (item.reference) { %>
                    <div class="break-all text-slate-500">Reference: <%= item.reference %></div>
                  <% } %>
                  <% if (item.customerId) { %>
                    <div class="break-all text-slate-500">Customer: <%= item.customerId %></div>
                  <% } %>
                </div>
              <% }) %>
            </div>
          </div>

          <div class="rounded-lg border border-[#dbe3ec] bg-[#fbfcfd] p-4">
            <h2 class="font-semibold text-sm mb-3">Possible Duplicate Customers</h2>
            <% if (!goCardlessAnomalies.duplicateCustomerGroups.length) { %>
              <div class="text-sm text-slate-500">No duplicate-looking customers found in the latest scan.</div>
            <% } %>
            <div class="space-y-2">
              <% goCardlessAnomalies.duplicateCustomerGroups.forEach(group => { %>
                <div class="rounded-md border border-slate-200 bg-white p-3 text-xs">
                  <div class="font-semibold text-slate-800"><%= group[0]?.name || "Unnamed customer" %></div>
                  <% group.forEach(customer => { %>
                    <div class="mt-1 break-all text-slate-600">
                      <%= customer.id %>
                      <% if (customer.metadataKeys.length) { %>
                        &middot; metadata: <%= customer.metadataKeys.join(", ") %>
                      <% } %>
                    </div>
                  <% }) %>
                </div>
              <% }) %>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</body>
</html>
