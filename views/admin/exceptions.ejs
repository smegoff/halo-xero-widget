<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Admin Exceptions</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 text-gray-800">

<div class="max-w-6xl mx-auto mt-10 p-6 bg-white rounded-xl shadow">

  <h1 class="text-2xl font-bold mb-4">
    ⚠️ Mapping Exceptions
  </h1>

  <p class="text-gray-600 mb-6">
    Clients listed here are not correctly mapped to Xero and will fail in the widget.
  </p>

  <div class="grid grid-cols-2 gap-4 mb-6">
    <div class="p-4 bg-green-50 rounded">
      <div class="text-sm text-gray-500">Mapped Clients</div>
      <div class="text-xl font-semibold text-green-700">
        <%= mappedCount %>
      </div>
    </div>
    <div class="p-4 bg-red-50 rounded">
      <div class="text-sm text-gray-500">Unmapped Clients</div>
      <div class="text-xl font-semibold text-red-700">
        <%= unmappedCount %>
      </div>
    </div>
  </div>

  <% if (unmapped.length === 0) { %>
    <div class="p-4 bg-green-100 rounded text-green-800">
      🎉 No unmapped clients detected.
    </div>
  <% } else { %>
    <table class="w-full border-collapse">
      <thead>
        <tr class="border-b">
          <th class="text-left py-2">Halo Client</th>
          <th class="text-left py-2">Reason</th>
          <th class="text-left py-2">Last Updated</th>
        </tr>
      </thead>
      <tbody>
        <% unmapped.forEach(u => { %>
          <tr class="border-b hover:bg-gray-50">
            <td class="py-2 font-medium"><%= u.haloClientName %></td>
            <td class="py-2 text-red-600"><%= u.reason %></td>
            <td class="py-2 text-gray-500 text-sm">
              <%= new Date(u.updatedAt).toLocaleString("en-NZ") %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>

  <div class="mt-6">
    <a href="/admin" class="text-blue-600 hover:underline">
      ← Back to Admin Home
    </a>
  </div>

</div>

</body>
</html>
