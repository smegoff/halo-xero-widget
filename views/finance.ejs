<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Halo <> Xero Widget — <%= clientName %></title>
  <script src="https://cdn.tailwindcss.com"></script>

  <style>
    :root {
      --halo-teal: #0b7f7d;
      --halo-blue: #1f75bb;
      --halo-bg: #f3f6fa;
      --halo-line: #dbe3ec;
      --halo-text: #0f172a;
      --halo-muted: #64748b;
    }

    body {
      font-family: "Inter", "Segoe UI", Arial, sans-serif;
      background: var(--halo-bg);
      color: var(--halo-text);
      font-size: 14px;
    }

    .halo-shell {
      width: 100%;
      min-height: 100vh;
      padding: 14px 16px 18px;
    }

    .halo-panel {
      background: #ffffff;
      border: 1px solid var(--halo-line);
      border-radius: 8px;
      box-shadow: 0 1px 4px rgba(15, 23, 42, 0.12);
    }

    .halo-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 32px;
      padding: 7px 13px;
      border-radius: 16px;
      border: 1px solid #d8e1eb;
      background: #ffffff;
      color: #1f2937;
      font-size: 13px;
      font-weight: 500;
      line-height: 1;
      box-shadow: 0 1px 3px rgba(15, 23, 42, 0.12);
      transition: background 0.15s ease, border-color 0.15s ease, box-shadow 0.15s ease;
    }

    .halo-btn:hover {
      background: #f8fafc;
      border-color: #c9d4e0;
      box-shadow: 0 2px 6px rgba(15, 23, 42, 0.16);
    }

    .halo-btn-primary {
      background: var(--halo-teal);
      border-color: var(--halo-teal);
      color: #ffffff;
    }

    .halo-btn-primary:hover {
      background: #096f6d;
      border-color: #096f6d;
    }

    .halo-btn-danger {
      background: #ffffff;
      border-color: #f1c7c7;
      color: #b42318;
    }

    .halo-input {
      height: 34px;
      border: 1px solid #d8e1eb;
      border-radius: 8px;
      background: #ffffff;
      color: #334155;
      font-size: 13px;
      box-shadow: inset 0 1px 2px rgba(15, 23, 42, 0.04);
    }

    .halo-input:focus {
      outline: 2px solid rgba(31, 117, 187, 0.18);
      border-color: var(--halo-blue);
    }

    th.sorted-asc::after  { content: " ▲"; color: var(--halo-blue); font-size: 10px; }
    th.sorted-desc::after { content: " ▼"; color: var(--halo-blue); font-size: 10px; }
    tr.fade-in { animation: fadeIn 0.18s ease-in-out; }
    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  </style>
</head>

<body>
  <div class="halo-shell">
    <div class="halo-panel p-5">

<!-- Disclaimer -->
<div class="mb-4 rounded-md border border-amber-300 bg-amber-50 px-4 py-3 text-amber-900">
  <p class="text-[13px] leading-relaxed">
    <strong>This is an exact view of the client account in Xero.</strong>
    Payments received in the last <strong>24 hours</strong> may not appear until the next business day due to bank and Xero processing times.
  </p>
</div>

    <!-- Header row: title + refresh -->
    <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between mb-4">
      <div class="min-w-0">
        <h1 class="text-[21px] font-semibold leading-tight text-slate-900 mb-1">
          Client Xero Financial Summary - <span class="text-[#174ea6]"><%= clientName %></span>
        </h1>
        <p class="text-[13px] text-slate-500">
          As at <%= asAt %> — Tenant: <%= tenantName || "Xero" %>
          <% if (cacheStatus === "hit" || cacheStatus === "shared") { %>
            — Cached
          <% } %>
        </p>
      </div>

      <div class="flex items-center gap-2">
        <a
          href="/finance?area=<%= encodeURIComponent(area || clientName || '') %>&agentId=<%= agentId || '' %>&hmac=<%= encodeURIComponent(hmac || '') %>&refresh=1"
          class="halo-btn halo-btn-primary"
        >
          Refresh
        </a>
      </div>
    </div>

    <!-- Export buttons row -->
    <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between mb-4">
      <div class="flex flex-wrap gap-2">
        <a
          href="/finance/export-excel?key=<%= encodeURIComponent(cacheKey || '') %>&agentId=<%= encodeURIComponent(agentId || '') %>&token=<%= encodeURIComponent(exportToken || '') %>"
          class="halo-btn"
        >
          Export Excel
        </a>
        <a
          href="/finance/export-pdf?key=<%= encodeURIComponent(cacheKey || '') %>&agentId=<%= encodeURIComponent(agentId || '') %>&token=<%= encodeURIComponent(exportToken || '') %>"
          class="halo-btn halo-btn-danger"
        >
          Export PDF
        </a>
      </div>

      <!-- Search + outstanding toggle -->
      <div class="flex flex-wrap items-center gap-2 lg:justify-end">
        <input
          id="searchBox"
          type="text"
          placeholder="Search invoices..."
          class="halo-input w-full sm:w-48 md:w-64 px-3"
        />
        <button
          onclick="clearSearch()"
          class="halo-btn"
        >
          Clear
        </button>
        <label class="flex w-full sm:w-auto items-center gap-1 text-[13px] text-slate-700 whitespace-nowrap">
          <input
            id="outstandingToggle"
            type="checkbox"
            class="rounded border-slate-300"
          />
          Outstanding only
        </label>
      </div>
    </div>

    <!-- Account balances -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-5">
      <div class="px-4 py-3 bg-[#eef5fd] border border-[#dceaf8] rounded-md text-center">
        <div class="text-[13px] text-slate-500">Account Balance</div>
        <div class="text-[20px] font-semibold text-[#174ea6]">$<%= accountBal %></div>
      </div>
      <div class="px-4 py-3 bg-[#fff1f1] border border-[#f3d9d9] rounded-md text-center">
        <div class="text-[13px] text-slate-500">Overdue Balance</div>
        <div class="text-[20px] font-semibold text-[#b42318]">$<%= overdueBal %></div>
      </div>
    </div>

    <!-- Invoice table -->
    <div class="overflow-x-auto rounded-md border border-slate-200">
      <table id="invoiceTable" class="min-w-full">
        <thead class="bg-[#f4f6f8] border-b border-slate-200 select-none">
          <tr>
            <th onclick="sortTable(0)" class="py-2.5 px-3 text-left cursor-pointer text-[13px] font-semibold text-slate-800">Date</th>
            <th onclick="sortTable(1)" class="py-2.5 px-3 text-left cursor-pointer text-[13px] font-semibold text-slate-800">Type</th>
            <th onclick="sortTable(2)" class="py-2.5 px-3 text-left cursor-pointer text-[13px] font-semibold text-slate-800">Number</th>
            <th onclick="sortTable(3)" class="py-2.5 px-3 text-left cursor-pointer text-[13px] font-semibold text-slate-800">Due Date</th>
            <th onclick="sortTable(4)" class="py-2.5 px-3 text-left cursor-pointer text-[13px] font-semibold text-slate-800">Age</th>
            <th onclick="sortTable(5)" class="py-2.5 px-3 text-right cursor-pointer text-[13px] font-semibold text-slate-800">Total ($)</th>
            <th onclick="sortTable(6)" class="py-2.5 px-3 text-right cursor-pointer text-[13px] font-semibold text-slate-800">Due ($)</th>
          </tr>
        </thead>

        <tbody>
          <% rows.forEach(r => { %>
          <tr class="border-b border-slate-100 hover:bg-[#f7fafc] fade-in text-[13px]">
            <td class="py-2.5 px-3"><%= r.date %></td>
            <td class="py-2.5 px-3"><%= r.type %></td>
            <td class="py-2.5 px-3"><%= r.number %></td>
            <td class="py-2.5 px-3"><%= r.due %></td>

            <td class="py-2.5 px-3"><%= r.ageBucket || "" %></td>

            <!-- TOTAL with Xero formatting -->
            <td class="py-2.5 px-3 text-right" data-value="<%= r.total %>">
              <% if (r.total < 0) { %>
                <span class="text-green-700">(<%= Math.abs(r.total).toFixed(2) %>)</span>
              <% } else { %>
                <%= r.total.toFixed(2) %>
              <% } %>
            </td>

            <!-- BALANCE with Xero formatting -->
            <td class="py-2.5 px-3 text-right" data-value="<%= r.balance %>">
              <% if (r.balance < 0) { %>
                <span class="text-green-700">(<%= Math.abs(r.balance).toFixed(2) %>)</span>
              <% } else { %>
                <%= r.balance.toFixed(2) %>
              <% } %>

              <% if (r.balance === 0) { %>
                <span class="ml-2 bg-green-100 text-green-700 border border-green-300 text-[10px] px-2 py-0.5 rounded-full">
                  PAID
                </span>
              <% } %>
            </td>
          </tr>
          <% }) %>
        </tbody>

        <tfoot class="bg-[#f8fafc] border-t border-slate-200 font-semibold text-[13px]">
          <tr>
            <td colspan="4" class="py-2.5 px-3 text-left">Totals</td>
            <td id="invoiceCount" class="py-2.5 px-3 text-left text-slate-600"></td>
            <td id="totalSum" class="py-2.5 px-3 text-right text-[#174ea6]"></td>
            <td id="balanceSum" class="py-2.5 px-3 text-right text-[#b42318]"></td>
          </tr>
        </tfoot>

      </table>
    </div>
    </div>
  </div>

  <script>
    // --- Search filter ---
    const searchBox = document.getElementById("searchBox");
    const outstandingToggle = document.getElementById("outstandingToggle");

    searchBox.addEventListener("input", applyFilters);
    outstandingToggle.addEventListener("change", applyFilters);

    function applyFilters() {
      const filter = searchBox.value.toLowerCase();
      const outstandingOnly = outstandingToggle.checked;
      const rows = document.querySelectorAll("#invoiceTable tbody tr");

      rows.forEach(row => {
        const text = row.innerText.toLowerCase();
        const balance = parseFloat(row.children[6].dataset.value) || 0;

        // Default filter behaviour
        let visible = text.includes(filter);

        // Corrected "outstanding only" logic
        if (outstandingOnly) {
          if (balance === 0) {
            visible = false;       // fully paid invoice → hide
          } else {
            visible = true;        // outstanding + credit notes → always show
          }
        }

        row.style.display = visible ? "" : "none";
      });

      updateTotals();
    }

    function clearSearch() {
      searchBox.value = "";
      searchBox.dispatchEvent(new Event("input"));
    }

    // --- Column sorting ---
    let currentSorted = null;
    let sortDirection = 1;

    function sortTable(colIndex) {
      const table = document.getElementById("invoiceTable");
      const rows = Array.from(table.querySelectorAll("tbody tr"));
      const headers = table.querySelectorAll("th");

      headers.forEach(h => h.classList.remove("bg-blue-50", "sorted-asc", "sorted-desc"));

      if (currentSorted === colIndex) sortDirection *= -1;
      else sortDirection = 1;

      headers[colIndex].classList.add("bg-blue-50");
      headers[colIndex].classList.add(sortDirection === 1 ? "sorted-asc" : "sorted-desc");

      currentSorted = colIndex;

      rows.sort((a, b) => {
        const A = parseFloat(a.children[colIndex].dataset.value || a.children[colIndex].innerText) || 0;
        const B = parseFloat(b.children[colIndex].dataset.value || b.children[colIndex].innerText) || 0;
        return sortDirection === 1 ? A - B : B - A;
      });

      rows.forEach(r => table.querySelector("tbody").appendChild(r));
      updateTotals();
    }

    // --- Totals ---
    function updateTotals() {
      const visibleRows = Array.from(
        document.querySelectorAll("#invoiceTable tbody tr")
      ).filter(r => r.style.display !== "none");

      const totals = visibleRows.reduce(
        (acc, row) => {
          const total = parseFloat(row.children[5].dataset.value) || 0;
          const balance = parseFloat(row.children[6].dataset.value) || 0;
          acc.total += total;
          acc.balance += balance;
          return acc;
        },
        { total: 0, balance: 0 }
      );

      document.getElementById("invoiceCount").textContent =
        visibleRows.length + " items";
      document.getElementById("totalSum").textContent =
        "$" + totals.total.toFixed(2);
      document.getElementById("balanceSum").textContent =
        "$" + totals.balance.toFixed(2);
    }

    updateTotals();
  </script>
</body>
</html>
